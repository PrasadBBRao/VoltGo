# Flask
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1

# Security — replace these before running in any shared/staging/production environment
SECRET_KEY=change-me-to-a-long-random-secret
JWT_SECRET_KEY=change-me-to-a-long-random-jwt-secret

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=voltgo_dev
MYSQL_USER=voltgo_user
MYSQL_PASSWORD=strong_password

# CORS (comma-separated origins allowed)
CORS_ORIGINS=http://localhost:5173
